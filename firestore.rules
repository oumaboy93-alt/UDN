rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, codename, role, district, zone, isVerified, stats
    //
    // Collection: drops
    // Fields: id, sellerId, sellerCodename, title, description, category, price, quantity, maxQuantity, coordinates, zone, district, status, expiresAt, imageUrl
    //
    // Collection: orders
    // Fields: id, dropId, buyerId, sellerId, status, createdAt, updatedAt, price
    //
    // Collection: orders/{orderId}/messages
    // Fields: id, orderId, senderId, text, timestamp, isSystem
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'codename', 'role', 'district', 'zone', 'isVerified', 'stats']) &&
             data.uid is string && data.codename is string && data.codename.size() > 0 &&
             data.role in ['AGENT', 'OPERATOR', 'SELLER'] &&
             data.district is string && data.zone is string;
    }

    function isValidDrop(data) {
      return hasOnlyAllowedFields(['id', 'sellerId', 'sellerCodename', 'title', 'description', 'category', 'price', 'quantity', 'maxQuantity', 'coordinates', 'zone', 'district', 'status', 'expiresAt', 'imageUrl']) &&
             data.sellerId is string && data.title is string && data.title.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.coordinates is list && data.coordinates.size() == 2;
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['id', 'dropId', 'buyerId', 'sellerId', 'status', 'createdAt', 'updatedAt', 'price']) &&
             data.dropId is string && data.buyerId is string && data.sellerId is string &&
             data.status in ['PENDING', 'ACCEPTED', 'REJECTED', 'DELIVERED', 'COMPLETED', 'CANCELLED'];
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['id', 'orderId', 'senderId', 'text', 'timestamp', 'isSystem']) &&
             data.orderId is string && data.senderId is string && data.text is string && data.text.size() > 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /drops/{dropId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidDrop(request.resource.data) && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidDrop(request.resource.data) && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuthenticated() && isValidOrder(request.resource.data) && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
    }

    match /orders/{orderId}/messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.buyerId || request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.sellerId);
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.resource.data.senderId == request.auth.uid;
    }
  }
}
